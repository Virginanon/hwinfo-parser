{
  "name": "hwinfo-parser",
  "version": "1.0.0",
  "main": "./dist/index.node.js",
  "browser": "./dist/index.browser.js",
  "types": "./dist/types/index.browser.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "node": {
        "types": "./dist/types/index.node.d.ts",
        "default": "./dist/index.node.js"
      },
      "browser": {
        "types": "./dist/types/index.browser.d.ts",
        "default": "./dist/index.browser.js"
      },
      "types": "./dist/types/index.browser.d.ts",
      "default": "./dist/index.browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:node": "tsc -b tsconfig.node.json",
    "build:browser": "tsc -b tsconfig.app.json",
    "build": "tsc -b tsconfig.app.json tsconfig.node.json",
    "prepublishOnly": "npm run build",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "zhang pan",
  "license": "ISC",
  "description": "This is a provider of HWInfo parser services for craft-plugin-dev.",
  "repository": {
    "type": "git",
    "url": "git@github.com:Virginanon/hwinfo-parser.git"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
